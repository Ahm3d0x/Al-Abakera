{
  "name": "@mind-race/api",
  "version": "1.0.0",
  "private": true,
  "description": "Backend API and WebSocket Server for Mind Race",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npm run build --prefix ../../packages/shared && ncc build src/index.ts -o dist",
    "start": "node dist/index.js",
    "test": "jest"
  },
  "dependencies": {
    "@mind-race/shared": "*",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.107.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.11.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.12",
    "@types/supertest": "^7.2.0",
    "@vercel/ncc": "^0.38.4",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
